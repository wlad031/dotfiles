[user]
	email = gerasimovvs@yahoo.com
	name = Vladislav Gerasimov
[core]
	editor = nvim
    pager = delta
	excludesfile = /Users/vgerasimov/.gitignore_global
[push]
	default = current
[alias]
	commend = commit --amend --no-edit
	it = !git init && git commit -m 'Empty initialization commit' --allow-empty
	lg = log --oneline
	hist = log --graph --abbrev-commit --decorate --all \n--format=format:\"%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(dim white) - %an%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n %C(white)%s%C(reset)\"
	st = status --short --branch
	co = checkout
	cp = cherry-pick
  rbm = rebase origin/master
  cb = checkout -b
[delta]
	side-by-side = true
