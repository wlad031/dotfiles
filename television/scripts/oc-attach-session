#!/usr/bin/env bash
set -euo pipefail

line="$(tv opencode-sessions)"

scope="$(printf '%s' "$line" | awk '{print $2}' | cut -d: -f2)"
sid="$(printf '%s' "$line" | awk -F ' │ ' '{print $(NF-1)}')"
target="$(printf '%s' "$line" | awk -F ' │ ' '{print $NF}')"

if [ -z "$sid" ] || [ "$sid" = "null" ]; then
  printf 'Could not resolve session id from selection\n' >&2
  exit 1
fi

if [ "$scope" = "local" ]; then
  exec /sbin/opencode --session "$sid"
else
  exec /sbin/opencode attach "https://opencode.local.vgerasimov.dev" --session "$sid"
fi
