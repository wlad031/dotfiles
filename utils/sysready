#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: sysready.sh [config.yaml override.yaml ...] [--format json]

Checks tools defined in a YAML file.

Schema:
tools:
  - name: zsh
    command: zsh
    optional: true
    checks:
      - type: command
        value: zsh
      - type: dir
        value: ~/.config/zsh
      - type: apt
        value: zsh
      - type: pacman
        value: zsh
      - type: cargo
        value: ripgrep
      - type: npm
        value: typescript
      - type: uv
        value: ruff
      - type: env
        value: SSH_AUTH_SOCK
      - type: env
        value: PATH
        pattern: ".*~/.local/bin.*"
      - type: brew_formula
        value: tmux
      - type: brew_cask
        value: iterm2
      - type: snap
        value: core
      - type: flatpak
        value: org.mozilla.firefox
      - type: pipx
        value: httpie
      - type: pip
        value: requests
        venv: ~/.virtualenvs/myenv
      - type: uv_pip
        value: rich
        venv: ~/.virtualenvs/myenv
      - type: go_bin
        value: gopls
      - type: gem
        value: bundler
      - type: systemd_enabled
        value: ssh
      - type: systemd_active
        value: ssh
      - type: sha256
        value: ~/.ssh/id_ed25519.pub
        sha256: "<expected-hex>"
EOF
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "error: missing required command '$cmd'" >&2
    exit 2
  fi
}

detect_yq_flavor() {
  local version
  if ! version=$(yq --version 2>/dev/null); then
    echo "error: failed to run yq" >&2
    exit 2
  fi
  if [[ "$version" == *"mikefarah"* || "$version" == "yq version "* ]]; then
    printf '%s' "mikefarah"
    return 0
  fi
  if [[ "$version" == "yq "* ]]; then
    printf '%s' "python"
    return 0
  fi
  printf '%s' "unknown"
}

merge_configs() {
  local output="$1"
  shift
  local flavor="$1"
  shift
  case "$flavor" in
    mikefarah)
      yq eval-all 'reduce .[] as $item ({}; . * $item)' "$@" >"$output"
      ;;
    python)
      yq -y -s 'reduce .[] as $item ({}; . * $item)' "$@" >"$output"
      ;;
    *)
      echo "error: unsupported yq implementation" >&2
      return 1
      ;;
  esac
}

expand_path() {
  local value="$1"
  if [[ "$value" == "~" || "$value" == "~/"* ]]; then
    printf '%s' "${HOME}${value:1}"
  else
    printf '%s' "$value"
  fi
}

check_command() {
  local value="$1"
  local path
  path=$(command -v "$value" 2>/dev/null || true)
  if [[ -n "$path" ]]; then
    printf 'ok:%s' "$path"
  else
    printf 'fail:%s' "$value"
  fi
}

check_file() {
  local value
  value=$(expand_path "$1")
  if [[ -f "$value" ]]; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

check_dir() {
  local value
  value=$(expand_path "$1")
  if [[ -d "$value" ]]; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

check_executable() {
  local value
  value=$(expand_path "$1")
  if [[ -f "$value" && -x "$value" ]]; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

regex_escape() {
  local input="$1"
  local output=""
  local i ch
  for ((i = 0; i < ${#input}; i++)); do
    ch="${input:i:1}"
    case "$ch" in
      '\\'|'.'|'^'|'$'|'|'|'?'|'*'|'+'|'('|')'|'['|']'|'{'|'}')
        output+="\\$ch"
        ;;
      *) output+="$ch" ;;
    esac
  done
  printf '%s' "$output"
}

check_env() {
  local var="$1"
  local pattern="${2:-}"
  if [[ -z "${!var+x}" ]]; then
    printf 'fail:%s' "$var not set"
    return
  fi
  if [[ -n "$pattern" ]]; then
    if [[ "$pattern" == *"~"* ]]; then
      local home_escaped
      home_escaped=$(regex_escape "$HOME")
      pattern="${pattern//\~/$home_escaped}"
    fi
    if [[ "${!var}" =~ $pattern ]]; then
      printf 'ok:%s' "$var"
    else
      printf 'fail:%s' "$var does not match pattern"
    fi
  else
    printf 'ok:%s' "$var"
  fi
}

check_apt() {
  local value="$1"
  if ! command -v dpkg >/dev/null 2>&1; then
    printf 'fail:%s' "dpkg not available"
    return
  fi
  if dpkg -s "$value" >/dev/null 2>&1; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

check_pacman() {
  local value="$1"
  if ! command -v pacman >/dev/null 2>&1; then
    printf 'fail:%s' "pacman not available"
    return
  fi
  if pacman -Q "$value" >/dev/null 2>&1; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

_cargo_cache_ready=false
declare -A CARGO_PACKAGES

build_cargo_cache() {
  local line name
  if ! command -v cargo >/dev/null 2>&1; then
    return 1
  fi
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ "$line" == *: ]]; then
      name="${line%%:*}"
      if [[ -n "$name" ]]; then
        CARGO_PACKAGES["$name"]=1
      fi
    fi
  done < <(cargo install --list 2>/dev/null || true)
  _cargo_cache_ready=true
}

check_cargo() {
  local value="$1"
  if [[ "$_cargo_cache_ready" != true ]]; then
    if ! build_cargo_cache; then
      printf 'fail:%s' "cargo not available"
      return
    fi
  fi
  if [[ -n "${CARGO_PACKAGES[$value]:-}" ]]; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

_npm_cache_ready=false
declare -A NPM_PACKAGES

build_npm_cache() {
  local line base parent pkg
  if ! command -v npm >/dev/null 2>&1; then
    return 1
  fi
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    base="${line##*/}"
    parent="${line%/*}"
    parent="${parent##*/}"
    if [[ "$parent" == @* ]]; then
      pkg="$parent/$base"
    else
      pkg="$base"
    fi
    NPM_PACKAGES["$pkg"]=1
  done < <(npm ls -g --depth=0 --parseable 2>/dev/null | tail -n +2 || true)
  _npm_cache_ready=true
}

check_npm() {
  local value="$1"
  if [[ "$_npm_cache_ready" != true ]]; then
    if ! build_npm_cache; then
      printf 'fail:%s' "npm not available"
      return
    fi
  fi
  if [[ -n "${NPM_PACKAGES[$value]:-}" ]]; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

_uv_cache_ready=false
declare -A UV_TOOLS

build_uv_cache() {
  local line name
  if ! command -v uv >/dev/null 2>&1; then
    return 1
  fi
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    name="${line%%[[:space:]]*}"
    if [[ "$name" == "tool" || "$name" == "name" || "$name" == "--" ]]; then
      continue
    fi
    UV_TOOLS["$name"]=1
  done < <(uv tool list 2>/dev/null || true)
  _uv_cache_ready=true
}

check_uv() {
  local value="$1"
  if [[ "$_uv_cache_ready" != true ]]; then
    if ! build_uv_cache; then
      printf 'fail:%s' "uv not available"
