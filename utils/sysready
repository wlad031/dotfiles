    fi
    name="${line%%[[:space:]]*}"
    [[ -z "$name" ]] && continue
    UV_PIP_PACKAGES["$venv:$name"]=1
  done < <(uv pip list --python "$python_bin" 2>/dev/null || true)
  return 0
}

