check_systemd_active() {
  local value="$1"
  if ! command -v systemctl >/dev/null 2>&1; then
    printf 'fail:%s' "systemctl not available"
    return
  fi
  if systemctl is-active "$value" >/dev/null 2>&1; then
    printf 'ok:%s' "$value"
  else
    printf 'fail:%s' "$value"
  fi
}

get_sha256() {
  local value="$1"
  local hash
  if command -v sha256sum >/dev/null 2>&1; then
    read -r hash _ < <(sha256sum "$value")
    printf '%s' "$hash"
    return
  fi
  if command -v shasum >/dev/null 2>&1; then
    read -r hash _ < <(shasum -a 256 "$value")
    printf '%s' "$hash"
    return
  fi
  return 1
}

check_sha256() {
  local value="$1"
  local expected="$2"
  local path hash expected_lc hash_lc
  if [[ -z "$expected" ]]; then
    printf 'fail:%s' "sha256 not set"
    return
  fi
  path=$(expand_path "$value")
  if [[ ! -f "$path" ]]; then
    printf 'fail:%s' "$path"
    return
  fi
  if ! hash=$(get_sha256 "$path" 2>/dev/null); then
    printf 'fail:%s' "sha256 tool not available"
    return
  fi
  expected_lc=$(printf '%s' "$expected" | tr 'A-Z' 'a-z')
  hash_lc=$(printf '%s' "$hash" | tr 'A-Z' 'a-z')
  if [[ "$hash_lc" == "$expected_lc" ]]; then
    printf 'ok:%s' "$path"
  else
    printf 'fail:%s' "$path"
  fi
}

run_check() {
  local type="$1"
  local value="$2"
  local pattern="${3:-}"
  local venv="${4:-}"
  local sha256="${5:-}"
  case "$type" in
    command) check_command "$value" ;;
    file) check_file "$value" ;;
    dir) check_dir "$value" ;;
    executable) check_executable "$value" ;;
    apt) check_apt "$value" ;;
    pacman) check_pacman "$value" ;;
    cargo) check_cargo "$value" ;;
    npm) check_npm "$value" ;;
    uv) check_uv "$value" ;;
    env) check_env "$value" "$pattern" ;;
    brew_formula) check_brew_formula "$value" ;;
    brew_cask) check_brew_cask "$value" ;;
    snap) check_snap "$value" ;;
    flatpak) check_flatpak "$value" ;;
    pipx) check_pipx "$value" ;;
    pip) check_pip "$value" "$venv" ;;
    uv_pip) check_uv_pip "$value" "$venv" ;;
    go_bin) check_go_bin "$value" ;;
    gem) check_gem "$value" ;;
    systemd_enabled) check_systemd_enabled "$value" ;;
    systemd_active) check_systemd_active "$value" ;;
    sha256) check_sha256 "$value" "$sha256" ;;
    *) printf 'fail:%s' "unknown check type '$type'" ;;
  esac
}

format="text"
configs=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --format)
      shift
      if [[ "${1:-}" != "json" ]]; then
        echo "error: unsupported format '${1:-}'" >&2
        exit 2
      fi
      format="json"
      shift
      ;;
    *)
      configs+=("$1")
      shift
      ;;
  esac
done

if [[ ${#configs[@]} -eq 0 ]]; then
  configs=("$HOME/tools.yaml" "$HOME/tools.host.yaml")
fi

require_cmd yq

if [[ "$format" == "json" ]]; then
  require_cmd jq
fi

for config in "${configs[@]}"; do
  if [[ ! -f "$config" ]]; then
    echo "error: config not found: $config" >&2
    exit 2
  fi
done

merged_config=$(mktemp)
cleanup() {
  rm -f "$merged_config"
}
trap cleanup EXIT

yq_flavor=$(detect_yq_flavor)
if ! merge_configs "$merged_config" "$yq_flavor" "${configs[@]}"; then
  if [[ "$yq_flavor" == "python" ]]; then
    echo "error: failed to merge config files (python yq)" >&2
  elif [[ "$yq_flavor" == "mikefarah" ]]; then
    echo "error: failed to merge config files (mikefarah yq)" >&2
  else
    echo "error: failed to merge config files" >&2
  fi
  exit 2
fi

tool_count=0
installed_count=0
missing_required=0
missing_optional=0

tools_json=()

current_name=""
current_command=""
current_optional=""
missing_checks=()
tool_ok=true
command_path=""

finalize_tool() {
  if [[ -z "$current_name" ]]; then
    return
  fi

  if [[ "$tool_ok" == true ]]; then
    installed_count=$((installed_count + 1))
    status="OK"
  else
    if [[ "$current_optional" == "true" ]]; then
      missing_optional=$((missing_optional + 1))
      status="FAIL"
    else
      missing_required=$((missing_required + 1))
      status="FAIL"
    fi
  fi

  if [[ "$format" == "json" ]]; then
    missing_join=""
    if [[ ${#missing_checks[@]} -gt 0 ]]; then
      missing_join=$(printf '%s\n' "${missing_checks[@]}")
    fi
    required_json=true
    if [[ "$current_optional" == "true" ]]; then
      required_json=false
    fi
    tool_json=$(jq -n \
      --arg name "$current_name" \
      --arg command "$current_command" \
      --argjson required "$required_json" \
      --argjson installed "$tool_ok" \
      --arg missing "$missing_join" \
      '{name:$name, command:$command, required:$required, installed:$installed, missing_checks:($missing | split("\n") | map(select(length > 0)))}'
    )
    tools_json+=("$tool_json")
  else
    if [[ ${#missing_checks[@]} -gt 0 ]]; then
      details="missing: ${missing_checks[*]}"
    else
      details=""
    fi

    if [[ "$current_optional" == "true" ]]; then
      required_label="optional"
    else
      required_label="required"
    fi

    printf '%-30s %s\t%s\t%s\n' "$current_name" "$status" "$required_label" "$details"
  fi
}

while IFS=$'\t' read -r name command optional tool_fix check_type check_value check_pattern check_venv check_sha256 check_fix; do
  [[ -z "$name" ]] && continue

  if [[ -z "$current_name" ]]; then
    current_name="$name"
    current_command="$command"
    current_optional="$optional"
    tool_ok=true
    missing_checks=()
    command_path=""
    tool_count=$((tool_count + 1))
  elif [[ "$name" != "$current_name" ]]; then
    finalize_tool
    current_name="$name"
    current_command="$command"
    current_optional="$optional"
    tool_ok=true
    missing_checks=()
    command_path=""
    tool_count=$((tool_count + 1))
  fi

  for var in tool_fix check_pattern check_venv check_sha256 check_fix; do
    if [[ "${!var}" == "__NULL__" ]]; then
      printf -v "$var" ''
    fi
  done

  if [[ -z "$check_type" || -z "$check_value" ]]; then
    echo "error: invalid check in tool '$current_name'" >&2
    exit 2
  fi

  result=$(run_check "$check_type" "$check_value" "$check_pattern" "$check_venv" "$check_sha256")
  if [[ "$result" == ok:* ]]; then
    if [[ "$check_type" == "command" && -z "$command_path" ]]; then
      command_path="${result#ok:}"
    fi
  else
    tool_ok=false
    if [[ -z "$check_fix" ]]; then
      check_fix="$tool_fix"
    fi
    if [[ "$check_type" == "env" && -n "$check_pattern" ]]; then
      item="$check_type $check_value~$check_pattern"
    else
      item="$check_type $check_value"
    fi
    if [[ -n "$check_fix" ]]; then
      item="$item (fix: $check_fix)"
    fi
    missing_checks+=("$item")
  fi
done < <(
  yq -r '.tools // {} | to_entries[] | .key as $name | .value as $tool | ($tool.command // $name) as $cmd | ($tool.optional // false) as $opt | ($tool.fix // "__NULL__") as $tool_fix | ($tool.checks // []) as $checks | if ($checks|length)==0 then [$name,$cmd,$opt,$tool_fix,"command",$cmd,"__NULL__","__NULL__","__NULL__","__NULL__"] else $checks[] | [$name,$cmd,$opt,$tool_fix,.type,.value,(.pattern // "__NULL__"),(.venv // "__NULL__"),(.sha256 // "__NULL__"),(.fix // "__NULL__")] end | @tsv' "$merged_config"
)

finalize_tool

if [[ "$tool_count" -eq 0 ]]; then
  echo "error: no tools found in config" >&2
  exit 2
fi

total="$tool_count"

if [[ "$format" == "json" ]]; then
  tools_array=$(printf '%s\n' "${tools_json[@]}" | jq -s '.')
  jq -n \
    --argjson total "$total" \
    --argjson installed "$installed_count" \
    --argjson missing_required "$missing_required" \
    --argjson missing_optional "$missing_optional" \
    --argjson tools "$tools_array" \
    '{summary:{total:$total, installed:$installed, missing_required:$missing_required, missing_optional:$missing_optional}, tools:$tools}'
fi

if [[ "$missing_required" -gt 0 ]]; then
  exit 1
fi
