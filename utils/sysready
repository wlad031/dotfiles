_pip_cache_ready=false
declare -A PIP_VENV_PACKAGES

build_pip_venv_cache() {
  local venv="$1"
  local pip_bin line name
  venv=$(expand_path "$venv")
  pip_bin="$venv/bin/pip"
  if [[ ! -x "$pip_bin" ]]; then
    return 1
  fi
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    name="${line%%==*}"
    [[ -z "$name" ]] && continue
    PIP_VENV_PACKAGES["$venv:$name"]=1
  done < <("$pip_bin" list --format=freeze 2>/dev/null || true)
  return 0
}

check_pip() {
  local value="$1"
  local venv="$2"
  if [[ -z "$venv" ]]; then
    printf 'fail:%s' "pip venv not set"
    return
  fi
  venv=$(expand_path "$venv")
  if [[ "$_pip_cache_ready" != true ]]; then
    _pip_cache_ready=true
  fi
