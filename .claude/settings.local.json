{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/geras/.local/share/nvim/lazy/claude-preview.nvim/bin/claude-preview-diff.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/geras/.local/share/nvim/lazy/claude-preview.nvim/bin/claude-close-diff.sh"
          }
        ]
      }
    ]
  }
}
