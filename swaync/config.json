{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "bottom",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-width": 350,
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 0,
  "control-center-margin-left": 8,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-window-width": 350,
  "notification-icon-size": 60,
  "notification-body-image-height": 180,
  "notification-body-image-width": 180,
  "timeout": 12,
  "timeout-low": 6,
  "timeout-critical": 1,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "mpris",
    "title",
    "notifications",
    "volume",
    "backlight",
    "buttons-grid"
  ],
  "widget-config": {
    "title": {
      "text": "Notification Center",
      "clear-all-button": true,
      "button-text": "󰆴"
    },
    "label": {
      "max-lines": 1,
      "text": "Notification Center!"
    },

    "mpris": {
      "image-size": 80,
      "image-radius": 0
    },
    "volume": {
      "label": "󰕾 "
    },
    "backlight": {
      "label": "󰃟 "
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰝟",
          "type": "toggle",
          "command": "sh -c '[ \"$SWAYNC_TOGGLE_STATE\" = true ] && pactl set-sink-mute @DEFAULT_SINK@ 1 || pactl set-sink-mute @DEFAULT_SINK@ 0'",
          "update-command": "sh -c 'pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | grep -q yes && echo true || echo false'"
        },
        {
          "label": "󰍭",
          "type": "toggle",
          "command": "sh -c '[ \"$SWAYNC_TOGGLE_STATE\" = true ] && pactl set-source-mute @DEFAULT_SOURCE@ 1 || pactl set-source-mute @DEFAULT_SOURCE@ 0'",
          "update-command": "sh -c 'pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null | grep -q yes && echo true || echo false'"
        },

        {
          "label": "",
          "command": "kitty nmtui"
        },
        {
          "label": "",
          "command": "blueman-manager"
        },
        {
          "label": "󰤄",
          "type": "toggle",
          "command": "sh -c '[ \"$SWAYNC_TOGGLE_STATE\" = true ] && swaync-client -dn >/dev/null || swaync-client -df >/dev/null'",
          "update-command": "sh -c 'swaync-client -D 2>/dev/null || echo false'"
        },

        {
          "label": "󰀟",
          "command": "sh -c 'command -v gnome-network-displays >/dev/null 2>&1 && exec gnome-network-displays || notify-send swaync \"gnome-network-displays not installed\"'"
        },

        {
          "label": "󰈙",
          "command": "sh -c 'xdg-open \"$HOME/Documents\"'"
        },
        {
          "label": "",
          "command": "gnome-control-center"
        },
        {
          "label": "",
          "command": "sh -c 'xdg-open \"$HOME/notes\"'"
        },
        {
          "label": "",
          "command": "hyprlock"
        },
        {
          "label": "",
          "command": "systemctl reboot"
        },
        {
          "label": "",
          "command": "systemctl poweroff"
        }
      ]
    }
  }
}
